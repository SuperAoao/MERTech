import json
import os
import random
import re
import sys
from datetime import datetime

import matplotlib

matplotlib.use("Agg")

import numpy as np
import torch
import torch.nn.functional as F
from transformers import Wav2Vec2FeatureExtractor

sys.path.append("./function")
from function.config import (  # noqa: E402
    DATASET,
    EVAL_EVENT_GAP_SECONDS,
    EVAL_FRAME_THRESHOLD,
    EVAL_ONSET_THRESHOLD,
    EVAL_ONSET_TOLERANCE,
    MAX_MIDI,
    MIN_MIDI,
    MERT_SAMPLE_RATE,
    NUM_LABELS,
    URL,
    device,
    saveName,
    FREEZE_ALL,
)
from function.load_data import load  # noqa: E402
from function.metrics_ipt import (  # noqa: E402
    evaluate_ipt_chunks,
    format_ipt_test_report,
    metrics_to_json_serializable,
)
from function.model import SSLNet  # noqa: E402

# --- edit checkpoint path here ---
CHECKPOINT_PATH = "data/model/baseline/best_e_2225"
TEST_GROUP = ["test"]
RESULTS_DIR = "output/test_results"


def get_random_seed(seed: int = 42):
    random.seed(seed)
    os.environ["PYTHONHASHSEED"] = str(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    torch.cuda.manual_seed(seed)
    torch.backends.cudnn.deterministic = True
    torch.backends.cudnn.benchmark = False


def model_name_from_checkpoint(checkpoint_path: str) -> str:
    """e.g. data/model/baseline/best_e_2225 -> baseline_best_e_2225"""
    parent = os.path.basename(os.path.normpath(os.path.dirname(checkpoint_path)))
    base = os.path.basename(checkpoint_path)
    if parent and parent not in (".", os.sep):
        return f"{parent}_{base}"
    return base


def safe_filename(name: str) -> str:
    return re.sub(r"[^\w.\-]+", "_", name)


def start_test():
    get_random_seed(42)
    test_time = datetime.now()
    test_time_str = test_time.strftime("%Y%m%d_%H%M%S")
    model_name = model_name_from_checkpoint(CHECKPOINT_PATH)

    model = SSLNet(
        url=URL,
        class_num=NUM_LABELS * (MAX_MIDI - MIN_MIDI + 1),
        weight_sum=1,
        freeze_all=FREEZE_ALL,
    ).to(device)
    state_dict = torch.load(CHECKPOINT_PATH, map_location="cpu")
    model.load_state_dict(state_dict)
    model.eval()
    print("finishing loading model")

    wav_dir = DATASET + "/data"
    csv_dir = DATASET + "/labels"
    Xte, Yte, Yte_p, Yte_o, _, _ = load(wav_dir, csv_dir, TEST_GROUP, None, None)
    print("finishing loading dataset")

    processor = Wav2Vec2FeatureExtractor.from_pretrained(URL, trust_remote_code=True)

    pred_ipt_chunks = []
    tar_ipt_chunks = []
    pred_onset_chunks = []
    tar_onset_chunks = []

    print("start predicting...")
    with torch.no_grad():
        for i, x in enumerate(Xte):
            data = (
                processor(x, sampling_rate=MERT_SAMPLE_RATE, return_tensors="pt")[
                    "input_values"
                ]
                .float()
                .to(device)
            )
            target = Yte[i]
            target_o = Yte_o[i]
            IPT_pred, _, onset_pred = model(data)
            f_pred = F.sigmoid(IPT_pred.squeeze(0)).detach().cpu().numpy()
            o_pred = F.sigmoid(onset_pred.squeeze(0)).detach().cpu().numpy()

            t_len = target.shape[-1]
            pred_ipt_chunks.append(f_pred[:, :t_len].copy())
            tar_ipt_chunks.append(np.asarray(target[:, :t_len], dtype=np.float32))
            pred_onset_chunks.append(o_pred[:, :t_len].copy())
            tar_onset_chunks.append(np.asarray(target_o[:, :t_len], dtype=np.float32))

    ipt_metrics = evaluate_ipt_chunks(
        pred_ipt_chunks,
        tar_ipt_chunks,
        pred_onset_chunks,
        tar_onset_chunks,
        onset_th=EVAL_ONSET_THRESHOLD,
        frame_th=EVAL_FRAME_THRESHOLD,
        onset_tolerance=EVAL_ONSET_TOLERANCE,
        event_gap_seconds=EVAL_EVENT_GAP_SECONDS,
    )

    report = format_ipt_test_report(
        ipt_metrics,
        model_name=model_name,
        checkpoint_path=CHECKPOINT_PATH,
        test_time=test_time.strftime("%Y-%m-%d %H:%M:%S"),
        dataset=DATASET,
        test_group=",".join(TEST_GROUP),
    )

    os.makedirs(RESULTS_DIR, exist_ok=True)
    out_txt = os.path.join(
        RESULTS_DIR,
        safe_filename(f"{model_name}_{test_time_str}.txt"),
    )
    out_json = os.path.join(
        RESULTS_DIR,
        safe_filename(f"{model_name}_{test_time_str}.json"),
    )

    with open(out_txt, "w", encoding="utf-8") as f:
        f.write(report)
    with open(out_json, "w", encoding="utf-8") as f:
        json.dump(
            {
                "model_name": model_name,
                "save_name": saveName,
                "checkpoint": CHECKPOINT_PATH,
                "test_time": test_time.isoformat(),
                "dataset": DATASET,
                "test_group": TEST_GROUP,
                "metrics": metrics_to_json_serializable(ipt_metrics),
            },
            f,
            indent=2,
        )

    print(report)
    print(f"Saved report: {out_txt}")
    print(f"Saved JSON  : {out_json}")


if __name__ == "__main__":
    start_test()
